# ============================================================
# AWS credentials & region
# ============================================================
# Recommended: rely on `aws configure` / SSO / instance role and only set the
# REGION + PROFILE here. Avoid putting raw access keys in dotfiles.

AWS_REGION=us-east-1
AWS_PROFILE=default

# If you must use static creds (NOT recommended), uncomment:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # for STS / SSO

# ============================================================
# Agent runtime tuning
# ============================================================
# Hard cap on ReAct cycles (model calls) per user turn. Hook-enforced.
DEV_AGENT_MAX_ITERATIONS=25

# Bedrock model ID. Sonnet 4.5 needs the `us.` inference-profile prefix.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Skip per-tool confirmation prompts from strands-agents-tools.
# Set to "true" only when you trust the agent's environment.
BYPASS_TOOL_CONSENT=false

# Strands SDK log level: DEBUG | INFO | WARNING | ERROR
STRANDS_LOG_LEVEL=INFO
